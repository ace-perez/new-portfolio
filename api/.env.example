# ──────────────────────────────────────────────────────────────────────────────
# Blog API secrets — copy this to .env and fill in real values
# NEVER commit .env to git
# ──────────────────────────────────────────────────────────────────────────────

# Admin username for the blog CMS login
ADMIN_USERNAME=

# bcrypt hash of your admin password (cost factor 12).
# Generate with:
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"
# Or run from the api/ directory after npm install.
ADMIN_PASSWORD_HASH=

# Long random string used to sign JWTs.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Absolute path to the SQLite database file inside the container.
# In Docker this maps to the blog_data volume. Keep this value as-is.
DB_PATH=/app/data/blog.db

# Comma-separated list of origins allowed by CORS (local dev only).
# In production, nginx proxies /api/ so same-origin requests bypass CORS.
ALLOWED_ORIGINS=http://localhost:5173

# ── New Relic APM ─────────────────────────────────────────────────────────────
NEW_RELIC_APP_NAME="Portfolio API"
NEW_RELIC_LICENSE_KEY=
